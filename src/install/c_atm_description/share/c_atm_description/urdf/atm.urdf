<?xml version="1.0"?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="atm">

    <xacro:include filename="$(find atm_description)/urdf/atm_gazebo.xacro"/>
    <link name="base_footprint"/>

    <joint name="base_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0.0 0.0 0.01" rpy="0 0 0"/>
    </joint>
    
    <link name="base_link">
        <visual>
            <origin xyz="-0.032 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <mesh filename="package://c_atm_description/meshes/burger_base.stl" scale= "0.001 0.001 0.001"/>
            </geometry>
            <material name="grey">
                <color rgba="0.8 0.8 0.8 1.0"/>
            </material>
        </visual>
        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <mass value="8.2573504e-01"/>
            <inertia ixx="2.2124416e-03" ixy="-1.2294101e-05" ixz="3.4938785e-05" iyy="2.1193702e-03" iyz="-5.0120904e-06" izz="2.0064271e-03"/>
        </inertial>
        <collision>
            <origin xyz="-0.032 0 0.070" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="0.140 0.140 0.143"/>
            </geometry>
        </collision>
    </link> 
    
    <!--left tire-->
    <joint name="baselink_lefttire" type="continuous">
        <origin xyz="0.0 0.08 0.023" rpy="-1.57 0 0"/>
        <parent link="base_link"/>
        <child link="left_tire"/>
        <axis xyz="0.0 0.0 1.0"/>
    </joint>
    <link name="left_tire">
        <visual >
            <origin xyz="0 0 0" rpy="1.57 0 0"/>
            <geometry>
                <mesh filename="package://c_atm_description/meshes/left_tire.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="black">
                <color rgba="0.0 0.0 0.0 1.0"/>
            </material>
        </visual>
        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <mass value="2.8498940e-02"/>
            <inertia ixx="1.1175580e-05" ixy="-4.2369783e-11" ixz="-5.9381719e-09" iyy="1.1192413e-05" iyz="-1.4400107e-11" izz="2.0712558e-05"/>
        </inertial>
        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder length="0.018" radius="0.033"/>
            </geometry>
        </collision>
    </link>
    
    <!--left tire-->
    <joint name="baselink_righttire" type="continuous">
        <origin xyz="0.0 -0.080 0.023" rpy="-1.57 0 0"/>
        <parent link="base_link"/>
        <child link="right_tire"/>
        <axis xyz="0.0 0.0 1.0"/>
    </joint>
    <link name="right_tire">
        <visual >
            <origin xyz="0 0 0" rpy="1.57 0 0"/>
            <geometry>
                <mesh filename="package://c_atm_description/meshes/right_tire.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="">
                <color rgba="1.0 0.0 0.0 1.0"/>
            </material>
        </visual>
        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <mass value="2.8498940e-02"/>
            <inertia ixx="1.1175580e-05" ixy="-4.2369783e-11" ixz="-5.9381719e-09" iyy="1.1192413e-05" iyz="-1.4400107e-11" izz="2.0712558e-05"/>
        </inertial>
        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder length="0.018" radius="0.033"/>
            </geometry>
        </collision>
    </link>

    <joint name="caster_back_joint" type="fixed">
        <parent link="base_link"/>
        <child link="caster_back_link"/>
        <origin xyz="-0.081 0 -0.004" rpy="-1.57 0 0"/>
  </joint>

  <link name="caster_back_link">
    <collision>
      <origin xyz="0 0.001 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.030 0.009 0.020"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" />
      <mass value="0.005" />
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001" />
    </inertial>
  </link>
</robot>
